<h1 class="title">Lista de Productos en Tiempo Real</h1>

<div class="formdiv">
  <form id="form" class="formProducto">
    <h4>Form para agregar producto</h4>
    <label>Product Name</label>
    <input type="text" id="title" name="title" />
    <label>Description</label>
    <input type="text" id="description" name="description" />
    <label>Code</label>
    <input type="text" id="code" name="code" />
    <label>Price</label>
    <input type="number" id="price" name="price" />
    <label>Status</label>
    <input type="checkbox" id="status" name="status" />
    <label>Stock</label>
    <input type="number" id="stock" name="stock" />
    <label>Category</label>
    <input type="text" id="category" name="category" />
    <input type="submit" value="Send" />
  </form>
</div>

<div class="formdiv">
  <form id="formDelete" class="formProducto">
    <h4>Form para eliminar Producto</h4>
    <label for="deleteCode">Product Code</label>
    <input type="text" id="deleteCode" name="deleteCode" />
    <input type="submit" value="Delete" />
  </form>
</div>

<p id="products"></p>

<script src="/socket.io/socket.io.js"></script>
<script src="/index.js"></script>

<style>
  .formdiv {
    display: flex;
    justify-content: center;
    margin-top: 20px;
    padding: 10px;
    border: solid;
  }
  .formProducto {
    display: flex;
    flex-direction: column;
    width: 300px;
  }

  .formProducto label {
    margin-top: 10px;
  }

  .formProducto input[type="submit"] {
    margin-top: 20px;
    padding: 10px;
    background-color: #333;
    color: #fff;
    border: none;
    cursor: pointer;
  }
</style>