    transition: background 0.3s ease;
  }
   
  
  .btn-page:disabled {
    background: #ccc;
    cursor: not-allowed;
    color: #999;
  }
  
  .page-numbers {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .page-number {
    min-width: 2.5rem;
    padding: 0.5rem 0.75rem;
    text-align: center;
    border: 1px solid #ddd;
    border-radius: 4px;
    text-decoration: none;
