<div class="products-wrapper">
<h1 class="products-title">Catálogo de Productos</h1>
  <div class="products-header">
    <div class="products-controls">
      <!-- Sort -->
      <div class="sort-control">
        <span class="control-label">Precio:</span>
        <a href="/api/products?limit={{currentLimit}}&page=1&sort=asc"
          class="btn-sort {{#ifEqual currentSort 'asc'}}active{{/ifEqual}}">
          ↑ Menor
        </a>
        <a href="/api/products?limit={{currentLimit}}&page=1&sort=desc"
          class="btn-sort {{#ifEqual currentSort 'desc'}}active{{/ifEqual}}">
          ↓ Mayor
        </a>
      </div>

      <!-- Limit -->
      <form class="limit-form" method="GET" action="/api/products">
        <input type="hidden" name="page" value="{{currentPage}}" />
        <input type="hidden" name="sort" value="{{currentSort}}" />
        <span class="control-label">Mostrar:</span>
        <input type="number" id="limit" name="limit" value="{{currentLimit}}" min="4" max="100" />
        <span class="control-label">por página</span>
        <button type="submit" class="btn-apply">Aplicar</button>
      </form>
    </div>
  </div>

  <!-- Paginación superior -->
  <div class="pagination-bar">
    <span class="pagination-info">Página <strong>{{currentPage}}</strong> de <strong>{{totalPages}}</strong></span>
    <div class="pagination-controls">
      {{#if hasPrevPage}}
        <a href="{{prevPage}}" class="btn-page">← Anterior</a>
      {{else}}
        <button class="btn-page" disabled>← Anterior</button>
      {{/if}}

      <div class="page-numbers">
        {{#each (range 1 totalPages)}}
          {{#ifEqual this ../currentPage}}
            <span class="page-number active">{{this}}</span>
          {{else}}
            <a href="/api/products?limit={{../currentLimit}}&page={{this}}&sort={{../currentSort}}" class="page-number">{{this}}</a>
          {{/ifEqual}}
        {{/each}}
      </div>

      {{#if hasNextPage}}
        <a href="{{nextPage}}" class="btn-page">Siguiente →</a>
      {{else}}
        <button class="btn-page" disabled>Siguiente →</button>
      {{/if}}
    </div>
  </div>

  {{#if products.length}}
    <div class="products-grid">
      {{#each products}}
        <div class="product-card">
          {{#if this.thumbnails}}
            <div class="product-image">
              <img src="{{this.thumbnails}}" alt="{{this.title}}" />
            </div>
          {{else}}
            <div class="product-image product-image--empty">
              <span>Sin imagen</span>
            </div>
          {{/if}}

          <div class="product-body">
            <h3 class="product-name">{{this.title}}</h3>
            <p class="product-description">{{this.description}}</p>

            <div class="product-footer">
              <span class="product-price">${{this.price}}</span>
              <div class="product-actions">
                <a href="/api/products/{{this._id}}" class="btn-detail">Ver Detalles</a>
                {{#if this.stock}}
                  <div class="add-to-cart-inline">
                    <input type="number" class="qty-input" value="1" min="1" max="{{this.stock}}" />
                    <button class="btn-add btn-add-quick"
                      data-product-id="{{this._id}}"
                      data-product-stock="{{this.stock}}">
                      🛒
                    </button>
                  </div>
                {{else}}
                  <span class="badge-agotado">Agotado</span>
                {{/if}}
              </div>
            </div>
          </div>
        </div>
      {{/each}}
    </div>

    <!-- Paginación inferior -->
    <div class="pagination-bar pagination-bar--bottom">
      <span class="pagination-info">Página <strong>{{currentPage}}</strong> de <strong>{{totalPages}}</strong></span>
      <div class="pagination-controls">
        {{#if hasPrevPage}}
          <a href="{{prevPage}}" class="btn-page">← Anterior</a>
        {{else}}
          <button class="btn-page" disabled>← Anterior</button>
        {{/if}}

        <div class="page-numbers">
          {{#each (range 1 totalPages)}}
            {{#ifEqual this ../currentPage}}
              <span class="page-number active">{{this}}</span>
            {{else}}
              <a href="/products?page={{this}}" class="page-number">{{this}}</a>
            {{/ifEqual}}
          {{/each}}
        </div>

        {{#if hasNextPage}}
          <a href="{{nextPage}}" class="btn-page">Siguiente →</a>
        {{else}}
          <button class="btn-page" disabled>Siguiente →</button>
        {{/if}}
      </div>
    </div>

  {{else}}
    <div class="no-products">
      <span>📦</span>
      <p>No hay productos disponibles</p>
    </div>
  {{/if}}

</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Serif+Display&display=swap');

  .products-wrapper {
    max-width: 90%;
    margin: 2.5rem auto;
    padding: 0 1.5rem;
    font-family: 'DM Sans', sans-serif;
    color: #1a1a1a;
  }

  /* ── Header ── */
  .products-header {
    display: flex;
    align-items: center;
    justify-content: end;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
    padding-bottom: 1.25rem;
  }

  .products-title {
    font-family: 'DM Serif Display', serif;
    font-size: 2.2rem;
    font-weight: 400;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .products-controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .control-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── Sort ── */
  .sort-control {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-sort {
    padding: 0.4rem 0.9rem;
    border-radius: 8px;
    border: 1.5px solid #e0e0e0;
    color: #555;
    background: white;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .btn-sort:hover {
    border-color: #1a1a1a;
    color: #1a1a1a;
  }

  .btn-sort.active {
    background: #1a1a1a;
    border-color: #1a1a1a;
    color: white;
  }

  /* ── Limit form ── */
  .limit-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0;
  }

  .limit-form input[type="number"] {
    width: 58px;
    padding: 0.4rem 0.5rem;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    text-align: center;
    transition: border-color 0.15s;
  }

  .limit-form input[type="number"]:focus {
    outline: none;
    border-color: #1a1a1a;
  }

  .btn-apply {
    padding: 0.4rem 0.9rem;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-apply:hover { background: #333; }

  /* ── Pagination ── */
  .pagination-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    background: #fafafa;
    border: 1.5px solid #f0f0f0;
    border-radius: 12px;
    margin-bottom: 2rem;
  }

  .pagination-bar--bottom {
    margin-top: 2rem;
    margin-bottom: 0;
  }

  .pagination-info {
    font-size: 0.88rem;
    color: #888;
  }

  .pagination-info strong {
    color: #1a1a1a;
    font-weight: 600;
  }

  .pagination-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn-page {
    padding: 0.4rem 0.85rem;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-page:hover { background: #333; }

  .btn-page:disabled {
    background: #e8e8e8;
    color: #bbb;
    cursor: not-allowed;
  }

  .page-numbers {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .page-number {
    min-width: 2.2rem;
    padding: 0.4rem 0.6rem;
    text-align: center;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    text-decoration: none;
    color: #555;
    background: white;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }

  .page-number:hover {
    border-color: #1a1a1a;
    color: #1a1a1a;
  }

  .page-number.active {
    background: #1a1a1a;
    color: white;
    border-color: #1a1a1a;
  }

  /* ── Grid ── */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* ── Card ── */
  .product-card {
    border: 1.5px solid #f0f0f0;
    border-radius: 14px;
    overflow: hidden;
    background: white;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    border-color: #e0e0e0;
  }

  .product-image {
    width: 100%;
    height: 180px;
    background: #f7f7f7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-image img {
    transform: scale(1.03);
  }

  .product-image--empty span {
    font-size: 0.8rem;
    color: #bbb;
    letter-spacing: 0.03em;
  }

  .product-body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 0.5rem;
  }

  .product-name {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.3;
  }

  .product-description {
    font-size: 0.85rem;
    color: #888;
    margin: 0;
    line-height: 1.5;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Footer de la card ── */
  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding-top: 0.85rem;
    border-top: 1px solid #f0f0f0;
    flex-wrap: wrap;
  }

  .product-price {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1a6b3c;
    white-space: nowrap;
  }

  .product-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .btn-detail {
    padding: 0.45rem 0.85rem;
    background: white;
    color: #1a1a1a;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s, background 0.15s;
  }

  .btn-detail:hover {
    border-color: #1a1a1a;
    background: #f7f7f7;
  }

  /* ── Qty inline ── */
  .add-to-cart-inline {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .qty-input {
    width: 46px;
    height: 32px;
    padding: 0 0.35rem;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    text-align: center;
    -moz-appearance: textfield;
    transition: border-color 0.15s;
  }

  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .qty-input:focus {
    outline: none;
    border-color: #1a6b3c;
  }

  .btn-add {
    height: 32px;
    padding: 0 0.75rem;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s, transform 0.1s;
  }

  .btn-add:hover { background: #333; }
  .btn-add:active { transform: scale(0.96); }

  .badge-agotado {
    font-size: 0.78rem;
    font-weight: 600;
    color: #aaa;
    background: #f5f5f5;
    padding: 0.3rem 0.65rem;
    border-radius: 6px;
    letter-spacing: 0.02em;
  }

  /* ── Empty state ── */
  .no-products {
    text-align: center;
    padding: 5rem 2rem;
    background: #fafafa;
    border-radius: 16px;
    border: 1.5px dashed #e0e0e0;
    color: #aaa;
  }

  .no-products span {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .no-products p {
    font-size: 1rem;
    margin: 0;
  }

  @media (max-width: 600px) {
    .products-header { flex-direction: column; align-items: flex-start; }
    .products-controls { flex-direction: column; align-items: flex-start; }
    .product-footer { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  document.querySelectorAll('.btn-add-quick').forEach(btn => {
    btn.addEventListener('click', async function () {
      const productId = this.dataset.productId;
      const stock = parseInt(this.dataset.productStock) || 1;
      const qtyInput = this.closest('.add-to-cart-inline').querySelector('.qty-input');
      const quantity = parseInt(qtyInput.value);

      if (!quantity || quantity < 1) {
        alert('Por favor indicá una cantidad válida');
        return;
      }
      if (quantity > stock) {
        alert(`Stock disponible: ${stock}`);
        return;
      }

      try {
        let cartId = localStorage.getItem('cartId');

        if (!cartId) {
          const cartResponse = await fetch('/api/carts', { method: 'POST' });
          const cart = await cartResponse.json();
          cartId = cart._id;
          localStorage.setItem('cartId', cartId);
        }

        const addResponse = await fetch(`/api/carts/${cartId}/product/${productId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quantity })
        });

        if (addResponse.ok) {
          alert('¡Producto agregado al carrito!');
          qtyInput.value = 1;
        } else {
          const error = await addResponse.json();
          alert('Error: ' + (error.message || 'No se pudo agregar el producto'));
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error al agregar el producto al carrito');
      }
    });
  });
</script>
