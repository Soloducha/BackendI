  }
  
  .quantity-row {
    margin: 1rem 0;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .quantity-row label {
    font-weight: 600;
  }
  
  .quantity-row input {
    width: 80px;
    padding: 0.5rem;
    border: 1px solid #ddd;
    border-radius: 4px;
