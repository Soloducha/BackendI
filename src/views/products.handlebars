<div class="products-container">
  <h1 class="title">Catálogo de Productos</h1>

    <!-- Paginación de productos -->
    <div class="pagination-container">
      <div class="pagination-info">
        <p>Página <strong>{{currentPage}}</strong> de <strong>{{totalPages}}</strong></p>
      </div>
      
      <div class="pagination-controls">
        {{#if hasPrevPage}}
          <a href="{{prevPage}}" class="btn-page">← Anterior</a>
        {{else}}
          <button class="btn-page" disabled>← Anterior</button>
        {{/if}}

            <div class="page-numbers">
            {{#each (range 1 totalPages)}}
                {{#ifEqual this ../currentPage}}
                <span class="page-number active">{{this}}</span>
                {{else}}
                <a href="/api/products?limit={{../currentLimit}}&page={{this}}&sort={{../currentSort}}" class="page-number">{{this}}</a>
                {{/ifEqual}}
            {{/each}}

        {{#if hasNextPage}}
          <a href="{{nextPage}}" class="btn-page">Siguiente →</a>
        {{else}}
          <button class="btn-page" disabled>Siguiente →</button>
        {{/if}}
      </div>
    </div>

    <!-- Control de límite -->
    <div class="limit-control">
    <form class="limit-form" method="GET" action="/api/products">
        <input type="hidden" name="page" value="{{currentPage}}" />
        <input type="hidden" name="sort" value="{{currentSort}}" />
        <label for="limit">Mostrar:</label>
        <input type="number" id="limit" name="limit" value="{{currentLimit}}" min="4" max="100" placeholder="{{currentLimit}}" />
        <span>productos por página</span>
        <button type="submit" class="btn btn-primary">Aplicar</button>
    </form>
    </div>

    <!-- Control de ordenamiento -->
    <div class="sort-control">
      <span class="sort-label">Ordenar por precio:</span>
      <a href="/api/products?limit={{currentLimit}}&page=1&sort=asc" class="btn-sort {{#ifEqual currentSort 'asc'}}active{{/ifEqual}}">
        ↑
      </a>
      <a href="/api/products?limit={{currentLimit}}&page=1&sort=desc" class="btn-sort {{#ifEqual currentSort 'desc'}}active{{/ifEqual}}">
        ↓
      </a>
    </div>
  
  {{#if products.length}}
    <div class="products-grid">
      {{#each products}}
        <div class="product-card">
          {{#if this.thumbnails}}
            <div class="product-image">
              <img src="{{this.thumbnails}}" alt="{{this.title}}" />
            </div>
          {{else}}
            <div class="product-image no-image">
              <span>Sin imagen</span>
            </div>
          {{/if}}
          
          <div class="product-body">
            <h3 class="productName">{{this.title}}</h3>
                        
            <p class="productDescription">{{truncate this.description 100}}</p>
            
            <div class="product-meta">
           
              <div class="meta-item">
                <span class="label">Precio:</span>
                <span class="productPrice">${{this.price}}</span>
              </div>
             
            </div>
            
            <div class="product-actions">
              <a href="/api/products/{{this._id}}" class="btn btn-primary">
                Ver Detalles
              </a>
              {{#if this.stock}}
                <button 
                  class="btn btn-success btn-add-quick" 
                  data-product-id="{{this._id}}"
                  data-product-title="{{this.title}}"
                  data-product-price="{{this.price}}"
                  data-product-stock="{{this.stock}}"
                >
                  🛒 Agregar
                </button>
              {{else}}
                <button class="btn btn-disabled" disabled>Agotado</button>
              {{/if}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>
    
    
  {{else}}
    <div class="no-products">
      <p>No hay productos disponibles</p>
    </div>
  {{/if}}
</div>

<!-- Modal para confirmación de agregar al carrito -->
<div id="modalAddCart" class="modal">
  <div class="modal-content">
    <span class="close">&times;</span>
    <h2>Agregar al Carrito</h2>
    <p>Producto: <strong id="modalProductName"></strong></p>
    <div class="quantity-row">
      <label for="modalQuantity">Cantidad:</label>
      <input type="number" id="modalQuantity" value="1" min="1" />
    </div>
    <div class="modal-actions">
      <button id="confirmAdd" class="btn btn-success">Confirmar</button>
      <button class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
    </div>
  </div>
</div>

<style>
