  }
  
  .product-image {
    width: 100%;
    height: 150px;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .product-image.no-image {
    background: #e9ecef;
  }
  
  .product-image.no-image span {
    color: #999;
    font-size: 1rem;
  }
  
  .product-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  
  .productName {
    font-size: 1.3rem;
    margin: 0 0 0.5rem 0;
    color: #333;
    font-weight: 600;
  }
  
  .productCode {
    font-size: 0.85rem;
    color: #999;
    margin: 0 0 0.5rem 0;
  }
  
  .productDescription {
    font-size: 0.95rem;
    color: #666;
    margin: 0 0 1rem 0;
    line-height: 1.4;
    flex-grow: 1;
  }
  
  .product-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: #f9f9f9;
    border-radius: 4px;
  }
  
  .meta-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
  }
  
  .meta-item .label {
    font-weight: 600;
    color: #555;
  }
  
  .productCategory {
    display: inline-block;
    background: #e3f2fd;
    color: #1976d2;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    font-size: 0.85rem;
  }
  
