<h1 class="title">Lista de Productos</h1>

<div class="product-list">
  {{#each products}}
    <div class="product-item">
      <div class="main">
        <span class="name">{{this.title}}</span>
        <span class="price">${{this.price}}</span>
      </div>

      <div class="secondary">
        <span>Desc: {{this.description}}</span>
        <span>Cod: {{this.code}}</span>
        <span>Stock: {{this.stock}}</span>
        <span>{{this.category}}</span>
        <span class="status {{this.status}}">
          status:
          {{this.status}}
        </span>
      </div>
    </div>
  {{/each}}
</div>

<style>
  body {
    font-family: Arial, sans-serif;
    background-color: #f7f7f7;
  }

  .title {
    font-size: 1.8rem;
    margin: 1.5rem;
    color: #333;
  }

  .product-list {
    width: 80%;
    margin: auto;
  }

  .product-item {
    background: #fff;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid #ddd;
  }

  .product-item:hover {
    background: #f0f0f0;
  }

  .main {
    display: flex;
    justify-content: space-between;
    font-weight: bold;
    margin-bottom: 0.2rem;
  }

  .name {
    color: #222;
  }

  .price {
    color: #2ecc71;
  }

  .secondary {
    font-size: 0.85rem;
    color: #666;
    display: flex;
    gap: 1rem;
  }

  .status {
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
  }

  .status.true {
    background: #d4edda;
    color: #155724;
  }

  .status.false {
    background: #f8d7da;
    color: #721c24;
  }
</style>